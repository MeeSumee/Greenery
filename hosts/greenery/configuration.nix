{
  pkgs,
  config,
  ...
}: {
  # All modules and their values
  greenery = {
    hardware = {
      enable = true;
      intelgpu.enable = true;
    };

    networking = {
      enable = true;
      dnscrypt.enable = true;
      fail2ban.enable = true;
      openssh.enable = true;
      tailscale = {
        enable = true;
        exitNode = true;
      };
    };

    programs = {
      enable = true;
      git.enable = true;
      nvim.enable = true;
    };

    server = {
      enable = true;
      files.enable = true;
      immich.enable = true;
      jellyfin.enable = true;
      memos.enable = true;
      suwayomi.enable = true;
    };

    system = {
      enable = true;
      autoUpgrade.enable = true;
      fish.enable = true;
      lanzaboote.enable = true;
      sumee.enable = true;
    };
  };

  # My precious everything
  networking.hostName = "greenery";

  # Enable non-nix executables for dynamic libraries such as minecraft scripts
  programs.nix-ld.enable = true;
  programs.nix-ld.libraries = with pkgs; [
    # Add any missing dynamic libraries for unpackaged programs
    # here, NOT in environment.systemPackages
  ];

  # Agenix keyfile
  age.secrets.secret1.file = ../../secrets/secret1.age;

  # Set borg backup service for greenery
  services = {
    # Define US dnscrypt proxy config
    dnscrypt-proxy.settings = {
      listen_addresses = [
        "100.65.16.29:53"
        "[fd7a:115c:a1e0::c437:101d]:53"
        "127.0.0.1:53"
        "[::1]:53"
      ];
    };

    # Borgbackup remote backup
    borgbackup.jobs = {
      prarie = {
        paths = ["/run/media/sumee/emerald"];
        repo = "ssh://sumee@seed//mnt/md0/repo";
        environment = {
          BORG_RSH = "ssh -i /home/sumee/.ssh/id_ed25519";
          BORG_RELOCATED_REPO_ACCESS_IS_OK = "yes";
        };
        encryption = {
          mode = "repokey-blake2";
          passCommand = "cat ${config.age.secrets.secret1.path}";
        };
        compression = "auto,zstd";
        startAt = "Wed 03:00:00";
      };
    };
  };

  # Set your time zone.
  time.timeZone = "America/Chicago";

  # This value determines the NixOS release from which the default
  # settings for stateful data, like file locations and database versions
  # on your system were taken. It‘s perfectly fine and recommended to leave
  # this value at the release version of the first install of this system.
  # Before changing this value read the documentation for this option
  # (e.g. man configuration.nix or on https://nixos.org/nixos/options.html).
  system.stateVersion = "24.11"; # Did you read the comment?
}
